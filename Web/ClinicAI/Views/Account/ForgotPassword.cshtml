@{
    Layout = null;
    ViewData["Title"] = "ClinicAI - Forgot Password";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />
    <script>
        (function () {
            const theme = localStorage.getItem('clinicai-theme') || 'dark';
            document.documentElement.setAttribute('data-theme', theme);
        })();
    </script>
    <style>
        .auth-body {
            display: flex; align-items: center; justify-content: center;
            min-height: 100vh; background: var(--bg-gradient); padding: 2rem 1rem;
        }
        .auth-card { width: 100%; max-width: 460px; }
        .auth-glass { padding: 3rem; border-radius: 24px; text-align: center; }
        .auth-header {
            margin-bottom: 2rem; padding-bottom: 1.75rem;
            border-bottom: 1px solid var(--card-border, rgba(255,255,255,0.06));
        }
        .auth-icon { font-size: 3rem; display: block; margin-bottom: 1rem; filter: drop-shadow(0 0 14px rgba(99,102,241,0.45)); color: var(--clr-primary); }
        .auth-title { font-size: 2rem; letter-spacing: -1px; margin-bottom: 0.5rem; font-weight: 800; color: var(--text-primary); }
        .auth-desc { color: var(--text-secondary); font-size: 0.95rem; margin-bottom: 0; line-height: 1.5; }
        .auth-alert-error { background: rgba(239,68,68,0.08); border: 1px solid rgba(239,68,68,0.2); padding: 0.85rem 1.15rem; border-radius: 12px; font-size: 0.85rem; }
        .auth-label { font-size: 0.78rem; letter-spacing: 0.06em; text-transform: uppercase; font-weight: 600; color: var(--text-secondary); margin-bottom: 0.45rem; }
        .auth-field { margin-bottom: 2rem; text-align: left; }
        .auth-field .glass-input { height: 48px; font-size: 0.95rem; }
        .auth-submit { height: 50px; font-size: 1rem; border-radius: 14px; font-weight: 600; letter-spacing: 0.02em; }
        .auth-back {
            font-size: 0.9rem; color: var(--text-secondary); text-decoration: none;
            display: inline-flex; align-items: center; gap: 0.4rem; transition: color 0.2s;
            margin-top: 1.25rem;
        }
        .auth-back:hover { color: var(--clr-primary); }
    </style>
</head>
<body class="auth-body">
    <div class="auth-card">
        <div class="glass-card animate-fade-in auth-glass">
            <!-- Header -->
            <div class="auth-header">
                <i class="fas fa-key auth-icon"></i>
                <h1 class="auth-title">Recover Password</h1>
                <p class="auth-desc">Enter your email address and we'll send you a 6-digit verification code</p>
            </div>
            
            <form asp-action="ForgotPassword" method="post">
                @Html.AntiForgeryToken()
                
                @if (!ViewData.ModelState.IsValid)
                {
                    <div asp-validation-summary="All" class="text-start text-danger auth-alert-error mb-4"></div>
                }
                
                <!-- Email field -->
                <div class="auth-field">
                    <label for="email" class="glass-label auth-label">
                        <i class="fas fa-envelope fa-xs me-1" style="opacity: 0.6;"></i> Email Address
                    </label>
                    <input type="email" id="email" name="email" class="glass-input" placeholder="e.g. user@clinicai.com" required autofocus autocomplete="off" />
                </div>
                
                <button type="submit" class="btn-glass w-100 auth-submit">
                    <i class="fas fa-paper-plane me-1"></i> Send Verification Code
                </button>
                
                <a href="@Url.Action("Login")" class="auth-back">
                    <i class="fas fa-arrow-left fa-xs"></i> Back to Sign In
                </a>
            </form>
        </div>
    </div>
</body>
</html>
