@model ClinicAI.ViewModels.Account.LoginVM
@{
    Layout = null;
    ViewData["Title"] = "ClinicAI - Sign In";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />
    <script>
        (function () {
            const theme = localStorage.getItem('clinicai-theme') || 'dark';
            document.documentElement.setAttribute('data-theme', theme);
        })();
    </script>
    <style>
        .auth-body {
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            background: var(--bg-gradient);
            padding: 2rem 1rem;
        }
        .auth-card {
            width: 100%;
            max-width: 460px;
        }
        .auth-glass {
            padding: 3rem;
            border-radius: 24px;
            text-align: center;
        }
        .auth-header {
            margin-bottom: 2rem;
            padding-bottom: 1.75rem;
            border-bottom: 1px solid var(--card-border, rgba(255,255,255,0.06));
        }
        .auth-icon {
            font-size: 3rem;
            display: block;
            margin-bottom: 1rem;
            filter: drop-shadow(0 0 14px rgba(99, 102, 241, 0.45));
            color: var(--clr-primary);
        }
        .auth-title {
            font-size: 2.25rem;
            letter-spacing: -1px;
            margin-bottom: 0.5rem;
            font-weight: 800;
            color: var(--text-primary);
        }
        .auth-desc {
            color: var(--text-secondary);
            font-size: 0.95rem;
            margin-bottom: 0;
            line-height: 1.5;
        }
        .auth-alert-error {
            background: rgba(239, 68, 68, 0.08);
            border: 1px solid rgba(239, 68, 68, 0.2);
            padding: 0.85rem 1.15rem;
            border-radius: 12px;
            font-size: 0.85rem;
        }
        .auth-alert-success {
            background: rgba(16, 185, 129, 0.08);
            border: 1px solid rgba(16, 185, 129, 0.2);
            color: var(--clr-success);
            font-size: 0.85rem;
            padding: 0.85rem 1.15rem;
            border-radius: 12px;
        }
        .auth-label {
            font-size: 0.78rem;
            letter-spacing: 0.06em;
            text-transform: uppercase;
            font-weight: 600;
            color: var(--text-secondary);
            margin-bottom: 0.45rem;
        }
        .auth-forgot-link {
            font-size: 0.78rem;
            color: var(--clr-primary);
            text-decoration: none;
            font-weight: 500;
            transition: color 0.2s;
        }
        .auth-forgot-link:hover {
            text-decoration: underline;
            color: var(--clr-primary-hover);
        }
        .auth-field {
            margin-bottom: 1.5rem;
            text-align: left;
        }
        .auth-field:last-of-type {
            margin-bottom: 2rem;
        }
        .auth-field .glass-input {
            height: 48px;
            font-size: 0.95rem;
        }
        .pwd-toggle-wrap {
            position: relative;
        }
        .pwd-toggle-wrap .glass-input {
            padding-right: 2.75rem;
        }
        .pwd-toggle-btn {
            position: absolute;
            right: 12px;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            color: var(--text-secondary);
            cursor: pointer;
            padding: 0;
            font-size: 0.9rem;
            line-height: 1;
            transition: color 0.2s;
        }
        .pwd-toggle-btn:hover {
            color: var(--clr-primary);
        }
        .auth-submit {
            height: 50px;
            font-size: 1rem;
            border-radius: 14px;
            font-weight: 600;
            letter-spacing: 0.02em;
        }
        .auth-validation {
            font-size: 0.78rem;
            margin-top: 0.35rem;
            display: block;
        }
    </style>
</head>
<body class="auth-body">
    <div class="auth-card">
        <div class="glass-card animate-fade-in auth-glass">
            <!-- Header -->
            <div class="auth-header">
                <i class="fas fa-brain auth-icon"></i>
                <h1 class="auth-title">ClinicAI</h1>
                <p class="auth-desc">Enter your credentials to access the clinical dashboard</p>
            </div>
            
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="auth-alert-success text-start mb-4">
                    <i class="fas fa-circle-check me-1"></i> @TempData["SuccessMessage"]
                </div>
            }

            <form asp-action="Login" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="ReturnUrl" />
                
                @if (!ViewData.ModelState.IsValid)
                {
                    <div asp-validation-summary="ModelOnly" class="text-start text-danger auth-alert-error mb-4"></div>
                }
                
                <!-- Username field -->
                <div class="auth-field">
                    <label asp-for="Username" class="glass-label auth-label">
                        <i class="fas fa-user fa-xs me-1" style="opacity: 0.6;"></i> Username
                    </label>
                    <input asp-for="Username" class="glass-input" placeholder="e.g. admin" required autofocus autocomplete="off" />
                    <span asp-validation-for="Username" class="text-danger auth-validation"></span>
                </div>
                
                <!-- Password field -->
                <div class="auth-field">
                    <div class="d-flex justify-content-between align-items-center" style="margin-bottom: 0.45rem;">
                        <label asp-for="Password" class="glass-label auth-label" style="margin: 0;">
                            <i class="fas fa-lock fa-xs me-1" style="opacity: 0.6;"></i> Password
                        </label>
                        <a href="@Url.Action("ForgotPassword")" class="auth-forgot-link">
                            <i class="fas fa-circle-question fa-xs me-1"></i>Forgot Password?
                        </a>
                    </div>
                    <div class="pwd-toggle-wrap">
                        <input asp-for="Password" class="glass-input" placeholder="••••••••" required id="loginPwd" />
                        <button type="button" class="pwd-toggle-btn" onclick="togglePwd('loginPwd', this)" aria-label="Toggle password visibility">
                            <i class="fas fa-eye"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="text-danger auth-validation"></span>
                </div>
                
                <button type="submit" class="btn-glass w-100 auth-submit">
                    <i class="fas fa-right-to-bracket me-1"></i> Sign In
                </button>
            </form>
        </div>
    </div>

    <script>
        function togglePwd(inputId, btn) {
            const input = document.getElementById(inputId);
            const icon = btn.querySelector('i');
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.replace('fa-eye', 'fa-eye-slash');
            } else {
                input.type = 'password';
                icon.classList.replace('fa-eye-slash', 'fa-eye');
            }
        }
    </script>
</body>
</html>
