@model ClinicAI.ViewModels.Case.CaseFilterVM
@{
    ViewData["Title"] = "Case Management";
}

<link rel="stylesheet" href="~/css/dashboard.css" />

<div class="container-fluid py-4 animate-fade-in">
    <!-- Header -->
    <div class="row mb-4">
        <div class="col-12">
            <h1 class="font-weight-bold" style="letter-spacing: -0.5px;">Case Management</h1>
            <p class="text-muted">Monitor diagnostic cases, track priority states, and filter records dynamically.</p>
        </div>
    </div>

    <!-- Filters Panel -->
    <div class="glass-card mb-4" style="padding: 1.25rem;">
        <form method="get" asp-action="Index" class="row align-items-end">
            <!-- Disease Filter -->
            <div class="col-md-3 mb-2 mb-md-0">
                <label class="glass-label mb-1" style="font-size: 0.85rem;">Disease / Diagnosis</label>
                <select name="diseaseFilter" class="glass-input bg-dark text-white" style="height: 42px;">
                    <option value="">All Diseases</option>
                    @foreach (var item in Model.DiseasesList)
                    {
                        <option value="@item.Value" selected="@item.Selected">@item.Text</option>
                    }
                </select>
            </div>

            <!-- Doctor Filter -->
            <div class="col-md-3 mb-2 mb-md-0">
                <label class="glass-label mb-1" style="font-size: 0.85rem;">Assigned Doctor</label>
                <select name="doctorFilter" class="glass-input bg-dark text-white" style="height: 42px;">
                    <option value="">All Doctors</option>
                    @foreach (var item in Model.DoctorsList)
                    {
                        <option value="@item.Value" selected="@item.Selected">@item.Text</option>
                    }
                </select>
            </div>

            <!-- Date Filter -->
            <div class="col-md-3 mb-2 mb-md-0">
                <label class="glass-label mb-1" style="font-size: 0.85rem;">Creation Date</label>
                <input type="date" name="dateFilter" value="@(Model.SelectedDate?.ToString("yyyy-MM-dd"))" class="glass-input" style="height: 42px;" />
            </div>

            <!-- Buttons -->
            <div class="col-md-3 d-flex gap-2" style="gap: 0.5rem;">
                <button type="submit" class="btn-glass w-100" style="height: 42px; padding: 0;"><i class="fa-solid fa-magnifying-glass me-1"></i> Filter</button>
                <a href="@Url.Action("Index")" class="btn-glass-secondary w-100" style="height: 42px; padding: 0; align-items: center; display: inline-flex; justify-content: center;"><i class="fa-solid fa-rotate me-1"></i> Reset</a>
            </div>
        </form>
    </div>

    <!-- Case List -->
    <div class="glass-card">
        <div class="table-responsive">
            <table class="glass-table">
                <thead>
                    <tr>
                        <th>Case ID</th>
                        <th>Patient Name</th>
                        <th>Supervising Doctor</th>
                        <th>Primary Diagnosis</th>
                        <th>Status</th>
                        <th>Priority</th>
                        <th>Date Opened</th>
                        <th>Notes</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.CasesList != null && Model.CasesList.Any())
                    {
                        foreach (var c in Model.CasesList)
                        {
                            <tr>
                                <td class="font-weight-bold" style="color: #a5b4fc;">#@c.Id</td>
                                <td class="font-weight-bold">@c.PatientName</td>
                                <td>@c.DoctorName</td>
                                <td>
                                    <span class="status-badge" style="background: rgba(99, 102, 241, 0.1); color: #818cf8; border: 1px solid rgba(99, 102, 241, 0.2);">
                                        @c.PrimaryDiagnosis
                                    </span>
                                </td>
                                <td>
                                    <span class="status-badge" style="background: rgba(6, 182, 212, 0.1); color: #22d3ee; border: 1px solid rgba(6, 182, 212, 0.2);">
                                        @c.Status
                                    </span>
                                </td>
                                <td>
                                    @if (c.Priority == "High" || c.Priority == "Critical")
                                    {
                                        <span class="status-badge" style="background: rgba(239, 68, 68, 0.1); color: #f87171; border: 1px solid rgba(239, 68, 68, 0.2);">
                                            <i class="fa-solid fa-circle-exclamation me-1"></i> @c.Priority
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="status-badge" style="background: rgba(245, 158, 11, 0.1); color: #fbbf24; border: 1px solid rgba(245, 158, 11, 0.2);">
                                            <i class="fa-solid fa-triangle-exclamation me-1"></i> @c.Priority
                                        </span>
                                    }
                                </td>
                                <td>@c.CreatedAt.ToString("MMM dd, yyyy (hh:mm tt)")</td>
                                <td>
                                    <small class="text-muted">
                                        @(string.IsNullOrEmpty(c.AdditionalInformation) ? "No clinical notes attachment" : c.AdditionalInformation)
                                    </small>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center text-muted py-5">
                                No clinical cases found matching these filter criteria.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
