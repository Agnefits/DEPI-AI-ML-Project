@model ClinicAI.ViewModels.Report.ReportEditVM
@{
    ViewData["Title"] = "Clinical Report Review";
}

<link rel="stylesheet" href="~/css/dashboard.css" />

<div class="container-fluid py-4 animate-fade-in">
    <!-- Back Link -->
    <div class="mb-3">
        <a href="@Url.Action("Index")" class="text-muted text-decoration-none">← Back to Reports Center</a>
    </div>

    <!-- Header -->
    <div class="row mb-4">
        <div class="col-12">
            <h1 class="font-weight-bold">Clinical Report Review: @Model.PatientName</h1>
            <p class="text-muted">Review the AI model outputs, inspect the patient scan image, edit clinical descriptions, and sign off the diagnosis.</p>
        </div>
    </div>

    <div class="row">
        <!-- Left Side: AI Findings and Medical Scan -->
        <div class="col-lg-5 mb-4 mb-lg-0">
            <!-- Medical Image Panel -->
            <div class="glass-card mb-4">
                <h3 class="font-weight-bold mb-3" style="font-size: 1.15rem; color: #a5b4fc;"><i class="fas fa-image text-info me-2"></i> Patient Medical Scan</h3>
                @if (!string.IsNullOrEmpty(Model.MedicalImagePath))
                {
                    <div class="text-center bg-black rounded p-2" style="border: 1px solid var(--card-border);">
                        <img src="~/@Model.MedicalImagePath" class="img-fluid rounded" style="max-height: 350px; object-fit: contain;" alt="Patient Scan" />
                    </div>
                }
                else
                {
                    <div class="text-center text-muted py-5 rounded" style="background: rgba(0,0,0,0.2); border: 1px dashed var(--card-border);">
                        <span>No image scan available for this case.</span>
                    </div>
                }
            </div>

            <!-- AI Analytics Panel -->
            <div class="glass-card">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <h3 class="font-weight-bold mb-0" style="font-size: 1.15rem; color: #a5b4fc;"><i class="fas fa-robot text-primary me-2"></i> AI Diagnostic Insights</h3>
                    <span class="status-badge" style="background: rgba(6, 182, 212, 0.1); color: #22d3ee; border: 1px solid rgba(6, 182, 212, 0.2);">
                        Model: @Model.AIModelVersion
                    </span>
                </div>

                <div class="mb-3 d-flex align-items-center justify-content-between">
                    <span class="text-muted">AI Confidence Score</span>
                    <span class="font-weight-bold" style="font-size: 1.1rem; color: @(Model.AIConfidence >= 0.8 ? "#10b981" : "#f59e0b");">
                        @(Math.Round(Model.AIConfidence * 100, 1))%
                    </span>
                </div>

                <div class="progress mb-4" style="height: 6px; background: rgba(255,255,255,0.05); border-radius: 999px;">
                    <div class="progress-bar" role="progressbar" 
                         style="width: @(Model.AIConfidence * 100)%; background: linear-gradient(90deg, #6366f1, #06b6d4); border-radius: 999px;" 
                         aria-valuenow="@(Model.AIConfidence * 100)" aria-valuemin="0" aria-valuemax="100"></div>
                </div>

                <h4 class="font-weight-bold mb-2" style="font-size: 0.95rem;">Model Predictions & Findings:</h4>
                <ul class="list-unstyled mb-0" style="padding-left: 0;">
                    @if (Model.AIFindings != null && Model.AIFindings.Any())
                    {
                        foreach (var finding in Model.AIFindings)
                        {
                            <li class="d-flex align-items-center mb-2" style="gap: 0.5rem; font-size: 0.9rem;">
                                <span style="color: #6366f1;">•</span>
                                <span>@finding</span>
                            </li>
                        }
                    }
                    else
                    {
                        <li class="text-muted font-italic" style="font-size: 0.9rem;">No specific anomalies detected by the AI.</li>
                    }
                </ul>
            </div>
        </div>

        <!-- Right Side: Report Editor & Diagnosis Approval -->
        <div class="col-lg-7">
            <div class="glass-card">
                <h3 class="font-weight-bold mb-4" style="font-size: 1.25rem; color: #a5b4fc;"><i class="fas fa-pen text-primary me-2"></i> Clinical Report Editor</h3>
                
                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="CaseId" />
                    <input type="hidden" asp-for="PatientName" />
                    <input type="hidden" asp-for="Status" />
                    <input type="hidden" asp-for="ReportPdf" />

                    <!-- Report Content -->
                    <div class="mb-3">
                        <label asp-for="ReportContent" class="glass-label">Diagnostic Findings & Description</label>
                        <textarea asp-for="ReportContent" class="glass-input" rows="8" placeholder="Summarize anomalies, clinical observations, and diagnosis description..." required></textarea>
                        <span asp-validation-for="ReportContent" class="text-danger" style="font-size: 0.85rem;"></span>
                    </div>

                    <!-- Additional Recommendations -->
                    <div class="mb-4">
                        <label asp-for="AdditionalInformation" class="glass-label">Supplementary Information / Recommendations</label>
                        <textarea asp-for="AdditionalInformation" class="glass-input" rows="3" placeholder="Enter follow-up guidance, advice, or patient notes..."></textarea>
                        <span asp-validation-for="AdditionalInformation" class="text-danger" style="font-size: 0.85rem;"></span>
                    </div>

                    <!-- Diagnosis Approval Form -->
                    <div class="glass-card mb-4" style="background: rgba(255,255,255,0.02); border-color: rgba(255,255,255,0.05); padding: 1.25rem;">
                        <h4 class="font-weight-bold mb-3" style="font-size: 1.05rem; color: #a5b4fc;"><i class="fas fa-stethoscope text-primary me-2"></i> Diagnosis Certification (اعتماد التشخيص)</h4>
                        
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="DiagnosisName" class="glass-label">Confirmed Disease Name</label>
                                <input asp-for="DiagnosisName" class="glass-input" placeholder="e.g. Pneumonia" required />
                                <span asp-validation-for="DiagnosisName" class="text-danger" style="font-size: 0.85rem;"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="ICD10Code" class="glass-label">ICD-10 Medical Code</label>
                                <input asp-for="ICD10Code" class="glass-input" placeholder="e.g. J18.9" required />
                                <span asp-validation-for="ICD10Code" class="text-danger" style="font-size: 0.85rem;"></span>
                            </div>
                        </div>

                        <!-- Checkbox to approve -->
                        <div class="form-check form-switch mt-2">
                            <input asp-for="ApproveDiagnosis" class="form-check-input" type="checkbox" style="width: 40px; height: 20px; cursor: pointer;" />
                            <label class="form-check-label font-weight-bold text-white ms-2" for="ApproveDiagnosis">
                                Finalize diagnosis & sign off report (اعتماد التشخيص والتقرير)
                            </label>
                        </div>
                        <span class="text-muted d-block mt-1 ms-1" style="font-size: 0.8rem;">
                            By checking this box, you confirm the diagnostic report and log a digital sign-off.
                        </span>
                    </div>

                    @if (Model.Status == "Approved/Signed")
                    {
                        <div class="alert alert-success glass-card border-success mb-4" style="background: rgba(16, 185, 129, 0.08); color: #34d399; font-size: 0.9rem; padding: 1rem;">
                            <strong><i class="fas fa-signature text-success"></i> Signed:</strong> This report and diagnosis have already been finalized. Saving updates without checking the approval box will reset the status to pending.
                        </div>
                    }

                    <!-- Buttons -->
                    <div class="d-flex justify-content-end gap-3" style="gap: 1rem;">
                        <a href="@Url.Action("Index")" class="btn-glass-secondary">Cancel</a>
                        <button type="submit" class="btn-glass"><i class="fas fa-floppy-disk"></i> Update & Save Record</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
