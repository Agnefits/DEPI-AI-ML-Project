@model ClinicAI.Models.Hospital
@{
    ViewData["Title"] = "Edit Hospital";
}
<link rel="stylesheet" href="~/css/dashboard.css" />

<div class="container py-4 animate-fade-in" style="max-width: 600px;">
    <div class="mb-3">
        <a href="@Url.Action("Index")" class="text-muted text-decoration-none">← Back to Hospitals</a>
    </div>

    <div class="mb-4">
        <h1 class="font-weight-bold"><i class="fas fa-pen"></i> Edit Hospital</h1>
        <p class="text-muted">Modify registration details, location address, or active status.</p>
    </div>

    <div class="glass-card">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="CreatedAt" />

            <div class="mb-3">
                <label asp-for="Name" class="glass-label">Hospital Name</label>
                <input asp-for="Name" class="glass-input" required />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Email" class="glass-label">Email Address</label>
                <input asp-for="Email" type="email" class="glass-input" required />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Phone" class="glass-label">Phone Number</label>
                <input asp-for="Phone" class="glass-input" required />
                <span asp-validation-for="Phone" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Address" class="glass-label">Location / Address</label>
                <input asp-for="Address" class="glass-input" required />
                <span asp-validation-for="Address" class="text-danger"></span>
            </div>

            <div class="mb-4">
                <label class="glass-label d-block">Status</label>
                <div class="form-check form-switch">
                    <input asp-for="IsActive" class="form-check-input" type="checkbox" style="width: 40px; height: 20px; cursor: pointer;" />
                    <label class="form-check-label text-muted ms-2" for="IsActive">Mark as Active</label>
                </div>
            </div>

            <div class="d-flex justify-content-end gap-3" style="gap: 1rem;">
                <a href="@Url.Action("Index")" class="btn-glass-secondary">Cancel</a>
                <button type="submit" class="btn-glass"><i class="fas fa-floppy-disk"></i> Save Changes</button>
            </div>
        </form>
    </div>
</div>
