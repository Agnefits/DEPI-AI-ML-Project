@model IEnumerable<ClinicAI.Models.Subscription>
@{
    ViewData["Title"] = "Subscriptions Management";
    var isSuperAdmin = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value == "SuperAdmin";
}
<link rel="stylesheet" href="~/css/dashboard.css" />

<div class="container-fluid py-4 animate-fade-in">
    <div class="row mb-4 align-items-center">
        <div class="col-sm-6">
            <h1 class="font-weight-bold" style="letter-spacing: -0.5px;"><i class="fas fa-key"></i> Subscriptions</h1>
            <p class="text-muted">Monitor licenses, billing plans, and enrollment status for hospitals.</p>
        </div>
        <div class="col-sm-6 text-sm-end">
            @if (isSuperAdmin)
            {
                <a href="@Url.Action("Create")" class="btn-glass"><i class="fas fa-plus"></i> Create Subscription</a>
            }
        </div>
    </div>

    <div class="glass-card">
        <div class="table-responsive">
            <table class="glass-table">
                <thead>
                    <tr>
                        <th>Hospital</th>
                        <th>Plan Name</th>
                        <th>Price</th>
                        <th>Start Date</th>
                        <th>End Date</th>
                        <th>Status</th>
                        @if (isSuperAdmin)
                        {
                            <th>Actions</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var s in Model)
                        {
                            <tr>
                                <td class="font-weight-bold" style="color: #a5b4fc;">@(s.Hospital?.Name ?? $"Hospital #{s.HospitalId}")</td>
                                <td><span class="status-badge" style="background: rgba(99, 102, 241, 0.1); color: #a5b4fc; border: 1px solid rgba(99, 102, 241, 0.2);">@s.PlanName</span></td>
                                <td class="font-weight-bold" style="color: #10b981;">@s.Price.ToString("C")</td>
                                <td>@s.StartDate.ToString("MMM dd, yyyy")</td>
                                <td>@s.EndDate.ToString("MMM dd, yyyy")</td>
                                <td>
                                    @if (s.Status == "Active")
                                    {
                                        <span class="status-badge status-active">Active</span>
                                    }
                                    else
                                    {
                                        <span class="status-badge status-inactive">@s.Status</span>
                                    }
                                </td>
                                @if (isSuperAdmin)
                                {
                                    <td>
                                        <div class="d-flex align-items-center" style="gap: 0.5rem;">
                                            <a href="@Url.Action("Edit", new { id = s.Id })" class="btn-glass-secondary" style="padding: 0.4rem 0.8rem; font-size: 0.85rem; border-radius: 8px;">
                                                <i class="fas fa-pen"></i> Edit
                                            </a>
                                            <form asp-action="Delete" asp-route-id="@s.Id" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to cancel and delete this subscription?');">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn-glass-secondary" style="padding: 0.4rem 0.8rem; font-size: 0.85rem; border-radius: 8px; border-color: rgba(239, 68, 68, 0.2); color: #f87171;">
                                                    <i class="fas fa-trash"></i> Delete
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                }
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="@(isSuperAdmin ? 7 : 6)" class="text-center text-muted py-5">No subscriptions configured yet.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
