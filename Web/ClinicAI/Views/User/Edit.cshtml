@model ClinicAI.ViewModels.User.UserFormVM
@{
    ViewData["Title"] = "Edit Staff Member";
}

<link rel="stylesheet" href="~/css/dashboard.css" />

<div class="container py-4 animate-fade-in" style="max-width: 800px;">
    <!-- Back link -->
    <div class="mb-3">
        <a href="@Url.Action("Index")" class="text-muted text-decoration-none">← Back to Staff List</a>
    </div>

    <!-- Header -->
    <div class="mb-4">
        <h1 class="font-weight-bold">Edit Staff: @Model.FullName</h1>
        <p class="text-muted">Modify account configurations, permissions, or specialization settings.</p>
    </div>

    <!-- Error Summary -->
    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger glass-card border-danger mb-4" style="background: rgba(239, 68, 68, 0.1); color: #fca5a5;">
            <div asp-validation-summary="All" class="text-danger"></div>
        </div>
    }

    <!-- Form -->
    <div class="glass-card">
        <form asp-action="Edit" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="ImageUrl" />

            <div class="d-flex align-items-center mb-4" style="gap: 1.5rem;">
                <!-- Profile Image Preview -->
                <div style="width: 80px; height: 80px; border-radius: 50%; overflow: hidden; border: 3px solid rgba(255,255,255,0.15);">
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <img src="~/@Model.ImageUrl" alt="Profile" style="width: 100%; height: 100%; object-fit: cover;" />
                    }
                    else
                    {
                        <div class="w-100 h-100 d-flex align-items-center justify-content-center bg-dark text-white font-weight-bold" style="font-size: 1.5rem;">
                            @Model.FullName.Substring(0, Math.Min(2, Model.FullName.Length)).ToUpper()
                        </div>
                    }
                </div>
                <div>
                    <h5 class="m-0 font-weight-bold">Profile Picture</h5>
                    <p class="text-muted m-0" style="font-size: 0.85rem;">Upload a new image below to replace this profile picture.</p>
                </div>
            </div>

            <div class="row">
                <!-- Username -->
                <div class="col-md-6 mb-3">
                    <label asp-for="Username" class="glass-label">Username</label>
                    <input asp-for="Username" class="glass-input" required />
                    <span asp-validation-for="Username" class="text-danger"></span>
                </div>

                <!-- Full Name -->
                <div class="col-md-6 mb-3">
                    <label asp-for="FullName" class="glass-label">Full Name</label>
                    <input asp-for="FullName" class="glass-input" required />
                    <span asp-validation-for="FullName" class="text-danger"></span>
                </div>
            </div>

            <div class="row">
                <!-- Email -->
                <div class="col-md-6 mb-3">
                    <label asp-for="Email" class="glass-label">Email Address</label>
                    <input asp-for="Email" type="email" class="glass-input" required />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <!-- Password -->
                <div class="col-md-6 mb-3">
                    <label asp-for="Password" class="glass-label">Update Password (Optional)</label>
                    <input asp-for="Password" type="password" class="glass-input" placeholder="Leave empty to keep current password" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>
            </div>

            <div class="row">
                <!-- Phone -->
                <div class="col-md-6 mb-3">
                    <label asp-for="Phone" class="glass-label">Phone Number</label>
                    <input asp-for="Phone" class="glass-input" />
                    <span asp-validation-for="Phone" class="text-danger"></span>
                </div>

                <!-- Specialization -->
                <div class="col-md-6 mb-3">
                    <label asp-for="Specialization" class="glass-label">Specialization</label>
                    <input asp-for="Specialization" class="glass-input" placeholder="e.g. Chest Scans, Radiology Advisor" />
                    <span asp-validation-for="Specialization" class="text-danger"></span>
                </div>
            </div>

            <div class="row">
                <!-- Role selection -->
                <div class="col-md-6 mb-3">
                    <label asp-for="RoleId" class="glass-label">System Access Permission (Role)</label>
                    <select asp-for="RoleId" asp-items="Model.RolesList" class="glass-input bg-dark text-white" style="height: 48px;"></select>
                    <span asp-validation-for="RoleId" class="text-danger"></span>
                </div>

                <!-- Hospital Selection -->
                <div class="col-md-6 mb-3">
                    <label asp-for="HospitalId" class="glass-label">Assigned Hospital</label>
                    <select asp-for="HospitalId" asp-items="Model.HospitalsList" class="glass-input bg-dark text-white" style="height: 48px;">
                        <option value="">-- No Hospital / None --</option>
                    </select>
                    <span asp-validation-for="HospitalId" class="text-danger"></span>
                </div>
            </div>

            <div class="row">
                <!-- Active Status -->
                <div class="col-md-6 mb-3 d-flex align-items-center mt-4">
                    <div class="custom-control custom-switch">
                        <input asp-for="IsActive" type="checkbox" class="custom-control-input" id="isActiveSwitch" />
                        <label class="custom-control-label glass-label font-weight-normal" for="isActiveSwitch">Enable User Account (Is Active)</label>
                    </div>
                </div>
            </div>

            <!-- Profile image upload -->
            <div class="mb-4">
                <label asp-for="ImageFile" class="glass-label">Replace Profile Picture</label>
                <input asp-for="ImageFile" type="file" class="glass-input" accept="image/*" />
                <span asp-validation-for="ImageFile" class="text-danger"></span>
            </div>

            <!-- Form Actions -->
            <div class="d-flex justify-content-end gap-3 mt-4" style="gap: 1rem;">
                <a href="@Url.Action("Index")" class="btn-glass-secondary">Cancel</a>
                <button type="submit" class="btn-glass"><i class="fas fa-floppy-disk"></i> Save Changes</button>
            </div>
        </form>
    </div>
</div>
