@model ClinicAI.ViewModels.Dataset.DatasetUploadVM
@{
    ViewData["Title"] = "Model Training Dataset Management";
}

<link rel="stylesheet" href="~/css/dashboard.css" />

<div class="container-fluid py-4 animate-fade-in">
    <!-- Header -->
    <div class="row mb-4">
        <div class="col-12">
            <h1 class="font-weight-bold" style="letter-spacing: -0.5px;">Dataset Management</h1>
            <p class="text-muted">Upload and label diagnostic images (scans) for future AI model retraining.</p>
        </div>
    </div>

    <div class="row">
        <!-- Upload Form -->
        <div class="col-lg-4 mb-4">
            <div class="glass-card">
                <h4 class="mb-4 font-weight-bold"><i class="fas fa-upload text-primary me-2"></i> Upload Training Scan</h4>
                
                <form asp-action="Upload" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()

                    <!-- Label -->
                    <div class="mb-3">
                        <label asp-for="Label" class="glass-label">Diagnostic Classification (Label)</label>
                        <select asp-for="Label" asp-items="Model.LabelsList" class="glass-input bg-dark text-white" style="height: 48px;">
                            <option value="">-- Choose Label --</option>
                        </select>
                        <span asp-validation-for="Label" class="text-danger"></span>
                    </div>

                    <!-- Image upload -->
                    <div class="mb-4">
                        <label asp-for="ImageFile" class="glass-label">Select Scan Image</label>
                        <input asp-for="ImageFile" type="file" class="glass-input" accept="image/*" required />
                        <span asp-validation-for="ImageFile" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn-glass w-100"><i class="fas fa-upload"></i> Upload to Dataset</button>
                </form>
            </div>
        </div>

        <!-- Uploaded items grid -->
        <div class="col-lg-8 mb-4">
            <div class="glass-card h-100">
                <h4 class="mb-4 font-weight-bold"><i class="fas fa-layer-group text-primary me-2"></i> Retraining Dataset Repository</h4>
                <div class="table-responsive" style="max-height: 500px; overflow-y: auto;">
                    <table class="glass-table">
                        <thead>
                            <tr>
                                <th>Item ID</th>
                                <th>Scan Preview</th>
                                <th>Classification (Label)</th>
                                <th>Uploaded At</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.UploadedItems != null && Model.UploadedItems.Any())
                            {
                                foreach (var item in Model.UploadedItems)
                                {
                                    <tr>
                                        <td class="font-weight-bold" style="color: #a5b4fc;">#@item.Id</td>
                                        <td>
                                            <div style="width: 60px; height: 60px; border-radius: 8px; overflow: hidden; border: 1px solid rgba(255,255,255,0.1);">
                                                <a href="~/@item.ImagePath" target="_blank">
                                                    <img src="~/@item.ImagePath" alt="Scan" style="width: 100%; height: 100%; object-fit: cover;" />
                                                </a>
                                            </div>
                                        </td>
                                        <td>
                                            <span class="status-badge" style="background: rgba(99, 102, 241, 0.15); color: #a5b4fc; border: 1px solid rgba(99, 102, 241, 0.3);">
                                                @item.Label
                                            </span>
                                        </td>
                                        <td>@item.UploadedAt.ToString("MMM dd, yyyy (hh:mm tt)")</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4" class="text-center text-muted py-5">
                                        No training items uploaded yet. Use the upload panel to submit scan training data.
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
